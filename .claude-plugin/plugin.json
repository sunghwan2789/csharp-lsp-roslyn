{
  "name": "csharp-lsp-roslyn",
  "description": "C# language server for code intelligence",
  "version": "0.2.0",
  "author": {
    "name": "Your Name"
  },
  "repository": "https://github.com/sunghwan2789/csharp-lsp-roslyn",
  "category": "development",
  "strict": false,
  "lspServers": {
    "roslyn": {
      "command": "dotnet",
      "args": [
        "dnx",
        "-y",
        "--prerelease",
        "roslyn-language-server",
        "--",
        "--stdio",
        "--autoLoadProjects"
      ],
      "extensionToLanguage": {
        ".cs": "csharp"
      }
    }
  }
}
